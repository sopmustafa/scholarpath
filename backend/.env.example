# ─── Server ───────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# ─── Gmail SMTP ───────────────────────────────────────────────────
# Use your Gmail address
GMAIL_USER=yourname@gmail.com
# Generate an App Password (NOT your real password):
#   Google Account → Security → 2-Step Verification → App Passwords
#   Select "Mail" + "Other (ScholarPath)" → copy the 16-char password
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Groq AI (free) ───────────────────────────────────────────────
# Get your free key at: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=openai/gpt-oss-120b

# ─── Google OAuth ─────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/
# APIs & Services → Credentials → OAuth 2.0 Client IDs → Web Application
# Authorized origins: http://localhost:3000 and your production URL
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
